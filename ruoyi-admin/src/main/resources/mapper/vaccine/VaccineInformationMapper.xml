<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.vaccine.mapper.VaccineInformationMapper">
    
    <resultMap type="VaccineInformation" id="VaccineInformationResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="manufacturer"    column="manufacturer"    />
        <result property="description"    column="description"    />
        <result property="suitableAge"    column="suitable_age"    />
        <result property="stock"    column="stock"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectVaccineInformationVo">
        select id, name, manufacturer, description, suitable_age, stock, status, create_by, create_time, update_by, update_time from vaccine_information
    </sql>

    <select id="selectVaccineInformationList" parameterType="VaccineInformation" resultMap="VaccineInformationResult">
        <include refid="selectVaccineInformationVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="manufacturer != null and manufacturer != ''">
                AND manufacturer like concat('%', #{manufacturer}, '%')
            </if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="suitableAge != null  and suitableAge != ''"> and suitable_age = #{suitableAge}</if>
            <if test="stock != null "> and stock = #{stock}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectVaccineInformationById" parameterType="Long" resultMap="VaccineInformationResult">
        <include refid="selectVaccineInformationVo"/>
        where id = #{id}
    </select>

    <insert id="insertVaccineInformation" parameterType="VaccineInformation" useGeneratedKeys="true" keyProperty="id">
        insert into vaccine_information
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="manufacturer != null">manufacturer,</if>
            <if test="description != null">description,</if>
            <if test="suitableAge != null">suitable_age,</if>
            <if test="stock != null">stock,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="manufacturer != null">#{manufacturer},</if>
            <if test="description != null">#{description},</if>
            <if test="suitableAge != null">#{suitableAge},</if>
            <if test="stock != null">#{stock},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateVaccineInformation" parameterType="VaccineInformation">
        update vaccine_information
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="manufacturer != null">manufacturer = #{manufacturer},</if>
            <if test="description != null">description = #{description},</if>
            <if test="suitableAge != null">suitable_age = #{suitableAge},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteVaccineInformationById" parameterType="Long">
        delete from vaccine_information where id = #{id}
    </delete>

    <delete id="deleteVaccineInformationByIds" parameterType="String">
        delete from vaccine_information where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>